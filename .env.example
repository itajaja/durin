# Durin configuration. run.sh copies this to .env on first run and fills in
# SECRET_KEY. Restart the server after changing anything here.

# Session signing key. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Where the app listens. APP_URL must match what you type in the browser
# (it is also used as the Google OAuth redirect origin).
PORT=8400
APP_URL=http://localhost:8400

# --- Sign-in -----------------------------------------------------------
# Comma-separated list of emails allowed to sign in. Applies to BOTH Google
# and dev login. If empty, sign-in only works while DEV_LOGIN=true.
ALLOWED_EMAILS=giacomo.tag@gmail.com

# Local dev login (no Google needed): shows an email box on the login page.
# Anyone who can reach the server can sign in as any allowlisted email, so
# turn this off if the app is ever exposed beyond localhost.
DEV_LOGIN=true

# Google OAuth (optional until you create credentials — see README).
# Redirect URI to register in Google Cloud Console:
#   http://localhost:8400/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email sign-in via magic link (optional). Set both to enable; links are only
# sent to allowlisted emails. For Gmail, create an app password at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
# SMTP_HOST/SMTP_PORT default to smtp.gmail.com:587 (STARTTLS).
SMTP_USER=
SMTP_PASS=

# --- Syncing -----------------------------------------------------------
SYNC_INTERVAL_HOURS=6
# How far back the first sync asks for (banks usually return ~90 days).
HISTORY_DAYS=365
# Overlap window re-fetched on every sync so pending transactions update.
SYNC_OVERLAP_DAYS=7

# --- Storage -----------------------------------------------------------
# DATABASE_PATH=/absolute/path/to/durin.db   (default: ./data/durin.db)
